# Required
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# Database (PostgreSQL)
DATABASE_URL=postgresql://secubot:secubot_dev@localhost:5432/secubot

# Optional: horizontal scaling / locks / velocity state
REDIS_URL=redis://127.0.0.1:6379

# Comma-separated guild IDs where the bot is authoritative (empty = all guilds)
TRUSTED_OPERATOR_IDS=

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Node identity for multi-node deployments
NODE_ID=node-1
