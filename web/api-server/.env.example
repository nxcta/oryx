# Control API (Oryx) — local env

# Same Postgres as the bot (or dedicated control-plane DB in production)
DATABASE_URL=postgresql://secubot:secubot_dev@localhost:5432/secubot

CONTROL_API_HOST=0.0.0.0
CONTROL_API_PORT=4000

# Long random strings (openssl rand -hex 32)
AUDIT_PEPPER=change-me-to-32-plus-chars-minimum
ADMIN_API_TOKEN=change-me-to-24-plus-chars-minimum
COOKIE_SECRET=change-me-to-32-plus-chars-minimum

LOG_LEVEL=info
NODE_ENV=development

# Comma-separated origins for browser dashboards calling this API (credentials)
# CORS_ORIGINS=http://localhost:3101,http://localhost:3102
