{
  "name": "secubot",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise-grade Discord security, anti-nuke, and incident response platform",
  "type": "module",
  "workspaces": [
    "web/api-server"
  ],
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "node --import tsx src/index.ts",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "api:dev": "npm -w @secubot/api-server run dev",
    "api:build": "npm -w @secubot/api-server run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "discord-api-types": "^0.37.120",
    "discord.js": "^14.19.3",
    "ioredis": "^5.6.1",
    "pino": "^9.6.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "eslint": "^9.27.0",
    "prisma": "^6.8.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vitest": "^3.1.4"
  }
}
